{
  "name": "moodline",
  "version": "0.3.8",
  "description": "Statusline divertida e informativa para CLIs de IA (Claude Code, GitHub Copilot CLI e mais): barra de contexto em gradiente, emoji-humor, git, custo e trocadilhos de dev.",
  "type": "module",
  "bin": {
    "moodline": "bin/moodline.js"
  },
  "exports": {
    ".": "./lib/moodline-core.mjs"
  },
  "files": [
    "bin",
    "lib",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "node --test",
    "coverage": "node --test --experimental-test-coverage --test-coverage-exclude=\"test/**\" --test-coverage-lines=90 --test-coverage-functions=90 --test-coverage-branches=80"
  },
  "keywords": [
    "statusline",
    "status-line",
    "claude-code",
    "copilot-cli",
    "github-copilot",
    "ai-cli",
    "cli",
    "terminal",
    "prompt",
    "context-window",
    "tokens",
    "emoji",
    "developer-tools"
  ],
  "author": "Alison Amorim <alison.amorim.mail@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/slipalison/moodline.git"
  },
  "homepage": "https://github.com/slipalison/moodline#readme",
  "bugs": {
    "url": "https://github.com/slipalison/moodline/issues"
  }
}
